################################################################################
# IMPORTANT: .env file is TRACKED in this repo
################################################################################
# This means .env will be committed and shared
# Only add non-sensitive placeholder values to .env
# For actual secrets, use environment variables or CI/CD secrets
# Do NOT add .env to .gitignore - it is intentionally tracked
